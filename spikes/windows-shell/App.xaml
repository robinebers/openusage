<Application x:Class="OpenUsageShell.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="FlyoutBackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="FlyoutBorderBrush" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5C5C5C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626"/>
    </Application.Resources>
</Application>
