<Window x:Class="OpenUsageShell.FloatingStripWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenUsage"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        Width="120"
        Height="32"
        ShowActivated="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseRightButtonUp="Window_MouseRightButtonUp"
        MouseDoubleClick="Window_MouseDoubleClick"
        LocationChanged="Window_LocationChanged">
    <!-- Floating stand-in for the macOS menu-bar strip: dark chrome, white glyphs, stacked % -->
    <Border x:Name="Chrome"
            Background="#E6101010"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8,4"
            Cursor="SizeAll"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <ContentControl x:Name="Body"
                        Focusable="False"
                        UseLayoutRounding="True"
                        SnapsToDevicePixels="True"/>
    </Border>
</Window>
