<Window x:Class="OpenUsageShell.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenUsage"
        Width="372"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated"
        SourceInitialized="Window_SourceInitialized">
    <Border Background="#E8252527"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            CornerRadius="14"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="10" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- MaxHeight set in code from work-area so we only scroll when content truly overflows -->
            <ScrollViewer x:Name="ContentScroll"
                          Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="14,14,10,6"
                          CanContentScroll="False">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="6"/>
                        <Setter Property="Opacity" Value="0.35"/>
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel>
                    <TextBlock x:Name="RefreshingText"
                               Margin="2,0,6,10"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#64D2FF"
                               Text="Refreshing…"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="BannerText"
                               Margin="2,0,6,10"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#64D2FF"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="ErrorText"
                               Margin="2,0,6,10"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF453A"
                               Visibility="Collapsed"/>
                    <ItemsControl x:Name="ProviderList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2C2C2E"
                                        BorderBrush="#3A3A3C"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="0,12,0,10"
                                        Margin="0,0,6,12"
                                        Opacity="{Binding CardOpacity}">
                                    <StackPanel>
                                        <DockPanel Margin="14,0,14,10" LastChildFill="True">
                                            <ContentControl DockPanel.Dock="Right"
                                                            Content="{Binding Glyph}"
                                                            Margin="10,0,0,0"
                                                            VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F5F5F7"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="#3A3A3C"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding PlanVisibility}">
                                                    <TextBlock Text="{Binding Plan}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="#64D2FF"/>
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBlock Text="{Binding StatusLine}"
                                                   FontSize="12"
                                                   Foreground="#8E8E93"
                                                   Margin="14,0,14,6"
                                                   Visibility="{Binding StatusVisibility}"/>

                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="14,6,14,6">
                                                        <StackPanel Visibility="{Binding ProgressVisibility}">
                                                            <DockPanel Margin="0,0,0,5">
                                                                <TextBlock Text="{Binding Label}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#F5F5F7"
                                                                           DockPanel.Dock="Left"/>
                                                                <TextBlock Text="{Binding PaceText}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding BarBrush}"
                                                                           HorizontalAlignment="Right"
                                                                           TextAlignment="Right"/>
                                                            </DockPanel>
                                                            <!-- Capsule meter: fill color = pace (blue/amber/red) -->
                                                            <Grid Height="9">
                                                                <Border Background="#3A3A3C" CornerRadius="4.5"/>
                                                                <Border Background="{Binding BarBrush}"
                                                                        CornerRadius="4.5"
                                                                        HorizontalAlignment="Stretch"
                                                                        RenderTransformOrigin="0,0.5">
                                                                    <Border.RenderTransform>
                                                                        <ScaleTransform ScaleX="{Binding LeftFraction}"/>
                                                                    </Border.RenderTransform>
                                                                </Border>
                                                            </Grid>
                                                            <DockPanel Margin="0,6,0,0">
                                                                <TextBlock Text="{Binding PrimaryText}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding BarBrush}"
                                                                           DockPanel.Dock="Left"/>
                                                                <TextBlock Text="{Binding SecondaryText}"
                                                                           FontSize="12"
                                                                           Foreground="#8E8E93"
                                                                           HorizontalAlignment="Right"/>
                                                            </DockPanel>
                                                        </StackPanel>

                                                        <DockPanel Visibility="{Binding TextVisibility}">
                                                            <TextBlock Text="{Binding Label}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#F5F5F7"
                                                                       DockPanel.Dock="Left"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding PrimaryText}"
                                                                       FontSize="12"
                                                                       Foreground="{Binding ValueBrush}"
                                                                       HorizontalAlignment="Right"
                                                                       TextAlignment="Right"
                                                                       VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,1,0,0"
                    Padding="14,10,14,12"
                    Background="#1A000000"
                    CornerRadius="0,0,14,14">
                <DockPanel>
                    <Button Content="Refresh"
                            DockPanel.Dock="Right"
                            Padding="14,6"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="Refresh_Click"
                            Background="#0A84FF"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#409CFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <CheckBox x:Name="LaunchAtLoginCheck"
                              Content="Launch at Login"
                              FontSize="12"
                              Foreground="#AEAEB2"
                              VerticalAlignment="Center"
                              Checked="LaunchAtLogin_Changed"
                              Unchecked="LaunchAtLogin_Changed"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
